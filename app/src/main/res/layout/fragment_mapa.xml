<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp"
    tools:context=".MapaFragment">

    <TextView
        android:id="@+id/titleMapa"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ubicación y Sucursal"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/purple_700"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/subtitleMapa"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Identificación del área de trabajo actual"
        android:textSize="14sp"
        android:textColor="@color/gray_dark"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/titleMapa"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardUbicacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/subtitleMapa">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@android:drawable/ic_dialog_map"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp"
                app:tint="@color/purple_500"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Coordenadas GPS:"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/txtLatitud"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Latitud: Calculando..."
                android:textColor="@color/gray_dark"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/txtLongitud"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Longitud: Calculando..."
                android:textColor="@color/gray_dark"
                android:layout_marginTop="2dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sucursal Identificada:"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/txtSucursal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Buscando área..."
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/purple_700"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:padding="12dp"
                android:background="#F3E5F5" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnActualizarUbicacion"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="ACTUALIZAR UBICACIÓN"
        android:textStyle="bold"
        android:textColor="@color/white"
        app:cornerRadius="28dp"
        app:backgroundTint="@color/purple_500"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>